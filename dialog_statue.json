[
  {
    "type": "effect_on_condition",
    "id": "EOC_statue_startdialog",
    "//": "Called when interacting with the Island Heart. Starts the main dialog tree.",
    "effect": [
      { "open_dialogue": { "topic": "SKYISLAND_UPGRADE" } }
    ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_QUESTIONS",
    "dynamic_line": "Ask what you will.",
    "responses": [
      { "text": "Can you summarize this for me, briefly?", "topic": "SKYISLAND_WHAT" },
      { "text": "Explain expeditions.", "topic": "SKYISLAND_EXPLAIN1" },
      { "text": "Explain missions.", "topic": "SKYISLAND_EXPLAIN2" },
      { "text": "Explain upgrades.", "topic": "SKYISLAND_EXPLAIN3" },
      { "text": "Explain warp shards and rewards.", "topic": "SKYISLAND_EXPLAIN4" },
      { "text": "Explain services.", "topic": "SKYISLAND_EXPLAIN5" },
      { "text": "Let's return to discussing upgrades.", "topic": "SKYISLAND_UPGRADE" },
      { "text": "That's all for now.", "topic": "TALK_DONE" }
    ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_WHAT",
    "dynamic_line": "This underground laboratory is your base of operations in the Zone, hidden and secure. When ready, use the Spatial Anomaly Matrix to teleport to random locations throughout the Zone and begin an expedition. Hunt artifacts, eliminate threats, and reach the extraction point to return safely.\n\nShould you die, the Zone's anomalous fields will reconstruct you here, though you will lose EVERYTHING you were carrying.\n\nComplete expeditions, fulfill faction contracts, gather supplies, upgrade your laboratory, and prepare for increasingly dangerous ventures into the Zone. Eventually, you'll become a legendary Stalker!\nGood hunting."
    "responses": [ { "text": "I see…", "topic": "SKYISLAND_QUESTIONS" } ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_EXPLAIN1",
    "dynamic_line": "Use the Spatial Anomaly Matrix to teleport to random locations in the Zone and begin an expedition. Find the extraction point marked on your PDA and reach it in time with all the artifacts and loot you can carry!\nDying on expedition triggers the lab's reconstruction protocol, but you'll lose EVERYTHING you had with you. Keep backup equipment in your stash for quick resupply!\n\nTime limits are enforced by anomalous field pulses that destabilize your cellular structure. After 8 pulses, you suffer anomaly sickness, rapidly degrading your abilities. After 12 pulses, your body begins breaking down at the molecular level, taking damage until you die. Return to base safely to reset your exposure!\n\nCertain laboratory upgrades can unlock access to new Zone regions or improve your resistance to anomalous effects."
    "responses": [ { "text": "Interesting…", "topic": "SKYISLAND_QUESTIONS" } ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_EXPLAIN2",
    "dynamic_line": "Once unlocked, faction contracts are randomly assigned when you begin an expedition. Most involve eliminating specific mutant threats or hostile Stalkers, and incomplete contracts are lost when you return to base. There's no penalty for failed contracts, so if they're too dangerous or remote, try again on your next outing. Completed contracts reward artifact fragments. Riskier contracts yield more fragments!\n\nYou can also unlock extermination contracts, requiring a minimum kill count during a single expedition. These can be completed anywhere in your operational area, but offer smaller fragment rewards."
    "responses": [ { "text": "Interesting…", "topic": "SKYISLAND_QUESTIONS" } ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_EXPLAIN3",
    "dynamic_line": "You can unlock and upgrade many laboratory systems. With the right resources, you can enhance your PDA's mapping range, increase available contracts per expedition, access new Zone regions, and even construct new facility modules.\n\nTo upgrade, accept an upgrade contract here, then deliver the required materials by crafting the associated technology. Find these under the Zone Tech category in your crafting menu.\n\nSome advanced upgrades require higher Stalker reputation. To rank up, survive enough expeditions and complete enough contracts - you'll be notified when rank advancement becomes available."
    "responses": [ { "text": "Interesting…", "topic": "SKYISLAND_QUESTIONS" } ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_EXPLAIN4",
    "dynamic_line": "Artifact fragments are earned by completing faction contracts. They can be processed into specialized Zone technology using your crafting station, and are required for laboratory upgrades. In emergencies, fragments can be consumed here for instant medical treatment.\n\nYou'll also collect resource caches, earned from any successful expedition regardless of contracts completed. Longer expeditions yield more caches. These can be processed into basic materials like wood, metal, chemicals, and electronics, provided you have fabrication nodes installed. Fabrication nodes come in three types for different resource categories and can be constructed using Zone Tech recipes."
    "responses": [ { "text": "Interesting…", "topic": "SKYISLAND_QUESTIONS" } ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_EXPLAIN5",
    "dynamic_line": "This laboratory control system offers various services. You can receive emergency medical treatment, neutralize ongoing psi-storms, review your operational statistics and reputation, and adjust expedition parameters.\n\nMedical treatment is complimentary until you've survived 10 expeditions. After that, treatment costs 4 artifact fragments per session.\n\nExpedition parameters default to standard settings for new Stalkers, but experienced operatives can adjust various factors to match their preferred operational style."
    "responses": [ { "text": "Interesting…", "topic": "SKYISLAND_QUESTIONS" } ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_UPGRADE",
    "dynamic_line": "Here you may invest your resources in facility upgrades."
    "responses": [
	  {
        "text": "Unlock: RANK UP 1",
        "condition": { "and": [ { "not": { "u_has_mission": "SKYISLAND_UPGRADE_rankup1" } }, { "math": [ "islandrank", "==", "1" ] } ] },
		"effect": [
          { "assign_mission": "SKYISLAND_UPGRADE_rankup1" }
        ],
        "topic": "SKYISLAND_UPGRADE"
      },
	  {
        "text": "Unlock: RANK UP 2",
        "condition": { "and": [ { "not": { "u_has_mission": "SKYISLAND_UPGRADE_rankup2" } }, { "math": [ "islandrank", "==", "3" ] } ] },
		"effect": [
          { "assign_mission": "SKYISLAND_UPGRADE_rankup2" }
        ],
        "topic": "SKYISLAND_UPGRADE"
      },
      { "text": "Upgrade the spatial anomaly matrix.", "topic": "SKYISLAND_UPGRADES_RAIDS" },
      { "text": "Enhance expedition parameters.", "topic": "SKYISLAND_UPGRADES_FEATURES" },
      { "text": "Laboratory construction.", "topic": "SKYISLAND_UPGRADES_INFRASTRUCTURE" },
      { "text": "I require laboratory services.", "topic": "SKYISLAND_SERVICES" },
      { "text": "I have some questions.", "topic": "SKYISLAND_QUESTIONS" },
      { "text": "Another time. Goodbye.", "topic": "TALK_DONE" }
    ]
  },
  {
    "type": "talk_topic",
    "id": "SKYISLAND_SERVICES",
    "dynamic_line": "How may the laboratory assist you?"
    "responses": [
      { 
	    "text": "Heal me. (Free)", 
        "condition": { "math": [ "islandrank", "==", "0" ] },
		"effect": [
		  { "run_eocs": [ "EOC_HEAL_NEWBIE" ] }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { 
	    "text": "Heal me. (Costs 4 Warp Shards)", 
        "condition": { "math": [ "islandrank", "!=", "0" ] },
		"effect": [
		  { "run_eocs": [ "EOC_HEAL_NEWBIE" ] }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { 
	    "text": "End an active portal storm.", 
		"effect": [
          { "run_eocs": [ "EOC_CANCEL_PORTAL_STORM" ] },
        {
          "u_message": "The air crackles with static electricity, then stabilizes.",
          "popup": true
        }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { 
	    "text": "View my expedition stats.", 
		"effect": [
          { "run_eocs": [ "EOC_statcheck" ] }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { 
	    "text": "View my upgrade stats.", 
		"effect": [
          { "run_eocs": [ "EOC_progresscheck" ] }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { 
	    "text": "View my construction stats.", 
		"effect": [
          { "run_eocs": [ "EOC_buildcheck" ] }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { 
	    "text": "Change my difficulty settings.", 
		"effect": [
          { "run_eocs": [ "EOC_difficultycheck" ] }
        ],
		"topic": "SKYISLAND_SERVICES" 
	  },
      { "text": "Let's return to discussing upgrades.", "topic": "SKYISLAND_UPGRADE" },
      { "text": "That's all. Goodbye.", "topic": "TALK_DONE" }
    ]
  },
